<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSplitTemplate"
    style="@style/Widget.FitTrack.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/stroke_subtle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Top row: emoji + name + difficulty badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSplitEmoji"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:textSize="22sp"
                android:background="@drawable/bg_circle_dark"
                android:text="💪" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvSplitName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Push Pull Legs"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSplitMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Days • Intermediate"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDifficultyBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="INT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_gold"
                android:background="@drawable/bg_badge_gold" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tvSplitDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Train chest, shoulders and triceps on push days..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="10dp" />

        <!-- Goal tag -->
        <TextView
            android:id="@+id/tvSplitGoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Muscle Hypertrophy"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_red"
            android:background="@drawable/bg_badge_red"
            android:layout_marginTop="10dp" />

        <!-- Selected indicator -->
        <TextView
            android:id="@+id/tvSelected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓  Selected"
            android:textColor="@color/accent_gold"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
