<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarMySplits"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_primary"
        app:title="My Splits"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary" />

    <!-- Schedule button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageSchedule"
        style="@style/Widget.FitTrack.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="📅 Manage Weekly Schedule" />

    <TextView
        android:id="@+id/tvNoSplits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No splits yet.\nTap + to choose a predefined program or build your own!"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="48dp"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMySplits"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabCreateSplit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Add Split"
        app:icon="@drawable/ic_add"
        app:backgroundTint="@color/accent_red"
        android:textColor="@color/text_primary" />

</LinearLayout>
