<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@color/bg_card"
    android:layout_marginBottom="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHistDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2026"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvHistStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80 kg × 3×10"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvHistVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2,400 kg vol"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="1dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvHistPR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ PR"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
