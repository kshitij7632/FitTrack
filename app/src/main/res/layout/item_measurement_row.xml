<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_row_alternate">

    <TextView
        android:id="@+id/tvMeasLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Body Weight"
        android:textColor="@color/text_primary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvMeasCurrent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="75.0 kg"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvMeasPrev"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="76.5 kg"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvMeasChange"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="-1.5 kg"
        android:textColor="@color/accent_red"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center" />

</LinearLayout>
