<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPRHistoryItem"
    style="@style/Widget.FitTrack.CardView"
    android:layout_width="100dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    app:strokeColor="@color/accent_gold"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvPRWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100 kg"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvPRDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/25"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
